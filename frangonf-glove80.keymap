                &kp EQUAL  &kp Q  &kp W  &kp E  &kp R  &kp T                                                                                                                                  &kp Y   &kp U   &kp I   &kp O   &kp P    &kp MINUS
                &kp GRAVE  &_LeftPinky(A, LAYER_QWERTY_Linux)  &_LeftRingy(S, LAYER_QWERTY_Linux)  &_LeftMiddy(D, LAYER_QWERTY_Linux)  &_LeftIndex(F, LAYER_QWERTY_Linux)  &kp G  &kp H  &_RightIndex(J, LAYER_QWERTY_Linux)  &_RightMiddy(K, LAYER_QWERTY_Linux)  &_RightRingy(L, LAYER_QWERTY_Linux)  &_RightPinky(SEMI, LAYER_QWERTY_Linux)  &kp SQT
                &mo LAYER_Lower_Linux  &kp Z  &kp X  &kp C  &kp V  &kp B  &thumb LAYER_Function_Linux ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System_Linux ENTER  &kp N  &kp M  &kp COMMA  &kp DOT  &kp FSLH  &mo LAYER_Lower_Linux
