/*
 * frangonf-glove80.keymap
 *
 * A single-file, documentation-first export of the live custom Glove80 ZMK layout
 * in this repository. This file is meant for reading, reviewing, and formatting in
 * qmk.nvim; the firmware source of truth is still:
 *
 *   - app/boards/arm/glove80/glove80.keymap
 *   - app/boards/arm/glove80/includes/layers/*.dtsi
 *   - app/boards/arm/glove80/includes/behaviors/*.dtsi
 *   - app/boards/arm/glove80/includes/combos.dtsi
 *
 * qmk.nvim notes:
 * - The .keymap extension matches the plugin's default ZMK auto-format pattern.
 * - Use Treesitter's devicetree parser (set ft=dts if needed).
 * - This file keeps only the layer map readable in one place; it does not inline
 *   the ~7k lines of behavior/macro implementations behind emoji, world symbols,
 *   home-row mods, and mouse acceleration.
 *
 * Major architecture:
 * - Layers 0-31  : macOS-oriented stack
 * - Layers 32-63 : Linux-oriented mirror of the same stack
 * - Base layers  : 7 typing layouts per OS
 * - Finger layers: transient home-row-mod support layers
 * - Utility layers: cursor/number/function/emoji/world/symbol/system/mouse
 * - Safety layers: gaming/factory/lower/magic
 *
 * Important gotchas from the real implementation:
 * - The live keymap is modular. This export is flattened only at the layer level.
 * - Home-row behaviors are not plain keys: macros like LeftPinky(A, layer) expand
 *   into hold-tap behaviors with bilateral enforcement and OS-specific modifiers.
 * - macOS layers enable MACOS_CAGS_EXTEND, so E/C/I/, become extra Ctrl-capable
 *   positions on the base layouts. Linux mirrors do not use those exceptions.
 * - Magic and Factory layers are safety-critical. They preserve bootloader/reset/
 *   Bluetooth access even when other layers get complex.
 * - Emoji/world behaviors come from a fragile multi-file macros block in the real
 *   source. This export references those behavior names but does not re-inline the
 *   shared macro block on purpose.
 * - Combos are real behavior in the firmware, but combos live outside the layer map.
 *   See frangonf-glove80.md and includes/combos.dtsi for that chord layer.
 *
 * Binding order per layer follows the Glove80 80-key physical matrix:
 * - Row 1: top 5 left keys, top 5 right keys
 * - Row 2: 6 left matrix keys, 6 right matrix keys
 * - Row 3: 6 left matrix keys, 6 right matrix keys
 * - Row 4: 6 left matrix keys, 6 central thumb/inner keys, 6 right matrix keys
 * - Row 5: 5 left lower/outer keys, 6 central thumb/inner keys, 5 right lower/outer keys
 */

#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/pointing.h>

/*
 * Layer IDs copied from includes/helpers.dtsi so this export stays self-contained.
 * These names are the same names used by the live modular keymap.
 */
#define LAYER_QWERTY 0
#define LAYER_Enthium 1
#define LAYER_Engrammer 2
#define LAYER_Engram 3
#define LAYER_Dvorak 4
#define LAYER_Colemak 5
#define LAYER_ColemakDH 6
#define LAYER_Typing 7
#define LAYER_LeftPinky 8
#define LAYER_LeftRingy 9
#define LAYER_LeftMiddy 10
#define LAYER_LeftIndex 11
#define LAYER_RightPinky 12
#define LAYER_RightRingy 13
#define LAYER_RightMiddy 14
#define LAYER_RightIndex 15
#define LAYER_Cursor 16
#define LAYER_Number 17
#define LAYER_Function 18
#define LAYER_Emoji 19
#define LAYER_World 20
#define LAYER_Symbol 21
#define LAYER_System 22
#define LAYER_Mouse 23
#define LAYER_MouseFine 24
#define LAYER_MouseSlow 25
#define LAYER_MouseFast 26
#define LAYER_MouseWarp 27
#define LAYER_Gaming 28
#define LAYER_Factory 29
#define LAYER_Lower 30
#define LAYER_Magic 31

#define LAYER_QWERTY_Linux 32
#define LAYER_Enthium_Linux 33
#define LAYER_Engrammer_Linux 34
#define LAYER_Engram_Linux 35
#define LAYER_Dvorak_Linux 36
#define LAYER_Colemak_Linux 37
#define LAYER_ColemakDH_Linux 38
#define LAYER_Typing_Linux 39
#define LAYER_LeftPinky_Linux 40
#define LAYER_LeftRingy_Linux 41
#define LAYER_LeftMiddy_Linux 42
#define LAYER_LeftIndex_Linux 43
#define LAYER_RightPinky_Linux 44
#define LAYER_RightRingy_Linux 45
#define LAYER_RightMiddy_Linux 46
#define LAYER_RightIndex_Linux 47
#define LAYER_Cursor_Linux 48
#define LAYER_Number_Linux 49
#define LAYER_Function_Linux 50
#define LAYER_Emoji_Linux 51
#define LAYER_World_Linux 52
#define LAYER_Symbol_Linux 53
#define LAYER_System_Linux 54
#define LAYER_Mouse_Linux 55
#define LAYER_MouseFine_Linux 56
#define LAYER_MouseSlow_Linux 57
#define LAYER_MouseFast_Linux 58
#define LAYER_MouseWarp_Linux 59
#define LAYER_Gaming_Linux 60
#define LAYER_Factory_Linux 61
#define LAYER_Lower_Linux 62
#define LAYER_Magic_Linux 63

/*
 * qmk.nvim parser helpers:
 * The plugin's ZMK support is happiest when preprocessor-like binding starters use
 * underscore-prefixed names. These wrappers do not change the live firmware; they
 * only make this review/export file easier for qmk.nvim to tokenise consistently.
 */
#define _LeftPinky(key, layer_index) LeftPinky(key, layer_index)
#define _LeftRingy(key, layer_index) LeftRingy(key, layer_index)
#define _LeftMiddy(key, layer_index) LeftMiddy(key, layer_index)
#define _LeftIndex(key, layer_index) LeftIndex(key, layer_index)
#define _RightPinky(key, layer_index) RightPinky(key, layer_index)
#define _RightRingy(key, layer_index) RightRingy(key, layer_index)
#define _RightMiddy(key, layer_index) RightMiddy(key, layer_index)
#define _RightIndex(key, layer_index) RightIndex(key, layer_index)
#define _LeftMiddyExtendUp(key, layer_index) LeftMiddyExtendUp(key, layer_index)
#define _LeftMiddyExtendDown(key, layer_index) LeftMiddyExtendDown(key, layer_index)
#define _MiddyExtendUp(key, layer_index) MiddyExtendUp(key, layer_index)
#define _MiddyExtendDown(key, layer_index) MiddyExtendDown(key, layer_index)
#define _LeftPinkyRingy LeftPinkyRingy
#define _LeftPinkyMiddy LeftPinkyMiddy
#define _LeftPinkyIndex LeftPinkyIndex
#define _LeftRingyPinky LeftRingyPinky
#define _LeftRingyMiddy LeftRingyMiddy
#define _LeftRingyIndex LeftRingyIndex
#define _LeftMiddyPinky LeftMiddyPinky
#define _LeftMiddyRingy LeftMiddyRingy
#define _LeftMiddyIndex LeftMiddyIndex
#define _LeftIndexPinky LeftIndexPinky
#define _LeftIndexRingy LeftIndexRingy
#define _LeftIndexMiddy LeftIndexMiddy
#define _RightPinkyIndex RightPinkyIndex
#define _RightPinkyMiddy RightPinkyMiddy
#define _RightPinkyRingy RightPinkyRingy
#define _RightRingyIndex RightRingyIndex
#define _RightRingyMiddy RightRingyMiddy
#define _RightRingyPinky RightRingyPinky
#define _RightMiddyIndex RightMiddyIndex
#define _RightMiddyRingy RightMiddyRingy
#define _RightMiddyPinky RightMiddyPinky
#define _RightIndexMiddy RightIndexMiddy
#define _RightIndexRingy RightIndexRingy
#define _RightIndexPinky RightIndexPinky

/ {
    keymap {
        compatible = "zmk,keymap";

        /*
         * =========================================================================
         * macOS layers (0-31)
         * =========================================================================
         *
         * These are the primary layers for the default OPERATING_SYSTEM = 'M'
         * configuration in includes/behaviors/definitions.dtsi.
         */

        /*
         * Layer 0 — QWERTY (macOS default)
         * - Default everyday layer.
         * - A/S/D/F and J/K/L/; are home-row mods, not simple key presses.
         * - E/C/I/, use the macOS-only extended Ctrl exceptions.
         * - Lower is mirrored on both outer row-4 corners.
         * - Bottom thumbs fan out into emoji/cursor/number/typing/mouse/symbol/world.
         */
        layer_QWERTY {
            bindings = <
               &kp F1                         &kp F2                         &kp F3                         &kp F4                         &kp F5                                                                                                                                            &kp F6                          &kp F7                          &kp F8                            &kp F9                &kp F10
               &kp N0                         &kp N1                         &kp N2                         &kp N3                         &kp N4  &kp N5                                                                                                                                                     &kp N6                          &kp N7                          &kp N8                            &kp N9                &kp F12  &kp F11
               &kp EQUAL                      &kp Q                          &kp W         &_LeftMiddyExtendUp(E, LAYER_QWERTY)                         &kp R   &kp T                                                                                                                                                     &kp Y                           &kp U            &_MiddyExtendUp(I, LAYER_QWERTY)                          &kp O                &kp P    &kp MINUS
               &kp GRAVE         &_LeftPinky(A, LAYER_QWERTY)   &_LeftRingy(S, LAYER_QWERTY)   &_LeftMiddy(D, LAYER_QWERTY)   &_LeftIndex(F, LAYER_QWERTY)   &kp G                                                                                                                                                     &kp H   &_RightIndex(J, LAYER_QWERTY)   &_RightMiddy(K, LAYER_QWERTY)   &_RightRingy(L, LAYER_QWERTY)   &_RightPinky(SEMI, LAYER_QWERTY)   &kp SQT
              &mo LAYER_Lower                 &kp Z                          &kp X       &_LeftMiddyExtendDown(C, LAYER_QWERTY)                       &kp V   &kp B      &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp N  &kp M  &_MiddyExtendDown(COMMA, LAYER_QWERTY)  &kp DOT  &kp FSLH  &mo LAYER_Lower
            &magic LAYER_Magic 0            &kp GRAVE                      &kp LBKT                      &kp RBKT       &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &thumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 1 — Enthium (macOS)
         * - Same thumb and utility philosophy as QWERTY.
         * - Letter rows are rearranged for the Enthium alpha layout.
         */
        layer_Enthium {
            bindings = <
                &none                           &none                           &none                           &none                           &none                                                                                                                                                                                                                  &none                            &none                            &none                            &none                 &none
                &none                           &kp N1                          &kp N2                          &kp N3                          &kp N4     &kp N5                                                                                                                                                                     &kp N6                           &kp N7                           &kp N8                           &kp N9                &kp N0   &none
                &none                           &kp Z                           &kp Y                           &kp U                           &kp O   &kp SEMI                                                                                                                                                                     &kp Q                            &kp L                            &kp D                            &kp P                 &kp X    &none
                &kp W         &_LeftPinky(C, LAYER_Enthium)  &_LeftRingy(I, LAYER_Enthium)  &_LeftMiddy(E, LAYER_Enthium)  &_LeftIndex(A, LAYER_Enthium)  &kp COMMA                                                                                                                                                                    &kp K   &_RightIndex(H, LAYER_Enthium)  &_RightMiddy(T, LAYER_Enthium)  &_RightRingy(N, LAYER_Enthium)  &_RightPinky(S, LAYER_Enthium)  &kp F
              &mo LAYER_Lower                  &kp SQT                       &kp MINUS                       &kp EQUAL                        &kp DOT   &kp FSLH  &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp J  &kp M  &kp G  &kp B  &kp V  &mo LAYER_Lower
            &magic LAYER_Magic 0             &kp GRAVE                      &kp LBKT                        &kp RBKT         &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor SPACE      &thumb LAYER_Number TAB     &thumb LAYER_Typing INSERT  &thumb LAYER_Typing DELETE  &thumb LAYER_Mouse BACKSPACE  &space LAYER_Symbol R  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 2 — Engrammer (macOS)
         * - Another alpha-layout variant.
         * - Keeps the same cross-layer thumb access scheme as the other base layers.
         */
        layer_Engrammer {
            bindings = <
                &none                              &none                              &none                              &none                              &none                                                                                                                                                                                                                  &none                               &none                               &none                               &none                 &none
                &none                              &kp N1                             &kp N2                             &kp N3                             &kp N4     &kp N5                                                                                                                                                                     &kp N6                              &kp N7                              &kp N8                              &kp N9                &kp N0   &none
                &none                              &kp B                              &kp Y                              &kp O                              &kp U    &kp SQT                                                                                                                                                                     &kp SEMI                            &kp L                               &kp D                               &kp W                 &kp V    &kp Z
                &kp EQUAL      &_LeftPinky(C, LAYER_Engrammer)  &_LeftRingy(I, LAYER_Engrammer)  &_LeftMiddy(E, LAYER_Engrammer)  &_LeftIndex(A, LAYER_Engrammer)  &kp COMMA                                                                                                                                                                   &kp DOT &_RightIndex(H, LAYER_Engrammer)  &_RightMiddy(T, LAYER_Engrammer)  &_RightRingy(S, LAYER_Engrammer)  &_RightPinky(N, LAYER_Engrammer)  &kp Q
              &mo LAYER_Lower                      &kp G                              &kp X                              &kp J                              &kp K   &kp MINUS  &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp FSLH  &kp R  &kp M  &kp F  &kp P  &mo LAYER_Lower
            &magic LAYER_Magic 0                 &kp GRAVE                          &kp LBKT                           &kp RBKT         &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &thumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 3 — Engram (macOS)
         * - Uses custom Engram punctuation/mod-morph helpers like engram_QMARK.
         * - The left emoji thumb switches to thumb_engram_AT instead of plain BSLH.
         */
        layer_Engram {
            bindings = <
                &none                         &none                         &none                         &none                           &none                                                                                                                                                                                                                    &none                          &none                          &none                          &none                 &none
                &none                      &engram_N1                   &engram_N2                   &engram_N3                     &engram_N4     &engram_N5                                                                                                                                                                 &engram_N6                     &engram_N7                     &engram_N8                     &engram_N9            &engram_N0  &none
                &none                         &kp B                         &kp Y                         &kp O                           &kp U    &engram_SQT                                                                                                                                                                 &engram_DQT                    &kp L                          &kp D                          &kp W                 &kp V       &kp Z
                &engram_HASH   &_LeftPinky(C, LAYER_Engram)  &_LeftRingy(I, LAYER_Engram)  &_LeftMiddy(E, LAYER_Engram)    &_LeftIndex(A, LAYER_Engram)  &engram_COMMA                                                                                                                                                              &engram_DOT  &_RightIndex(H, LAYER_Engram)  &_RightMiddy(T, LAYER_Engram)  &_RightRingy(S, LAYER_Engram)  &_RightPinky(N, LAYER_Engram)  &kp Q
              &mo LAYER_Lower                 &kp G                         &kp X                         &kp J                           &kp K      &kp MINUS  &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &engram_QMARK  &kp R  &kp M  &kp F  &kp P  &mo LAYER_Lower
            &magic LAYER_Magic 0            &engram_FSLH                  &kp LBKT                      &kp RBKT        &thumb_engram_AT LAYER_Emoji 0  &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &thumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 4 — Dvorak (macOS)
         * - Dvorak alpha rearrangement with the same thumb/safety layer structure.
         */
        layer_Dvorak {
            bindings = <
                &none                         &none                         &none                         &none                         &none                                                                                                                                                                                                      &none                          &none                          &none                          &none                 &none
                &none                         &kp N1                        &kp N2                        &kp N3                        &kp N4  &kp N5                                                                                                                                                              &kp N6                         &kp N7                         &kp N8                         &kp N9                &kp N0   &none
                &none                         &kp SQT                       &kp COMMA                     &kp DOT                       &kp P   &kp Y                                                                                                                                                               &kp F                          &kp G                          &kp C                          &kp R                 &kp L    &kp SLASH
                &kp EQUAL       &_LeftPinky(A, LAYER_Dvorak)  &_LeftRingy(O, LAYER_Dvorak)  &_LeftMiddy(E, LAYER_Dvorak)  &_LeftIndex(U, LAYER_Dvorak)   &kp I                                                                                                                                                               &kp D   &_RightIndex(H, LAYER_Dvorak)  &_RightMiddy(T, LAYER_Dvorak)  &_RightRingy(N, LAYER_Dvorak)  &_RightPinky(S, LAYER_Dvorak)  &kp MINUS
              &mo LAYER_Lower                  &kp SEMI                      &kp Q                         &kp J                         &kp K   &kp X      &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp B  &kp M  &kp W  &kp V  &kp Z  &mo LAYER_Lower
            &magic LAYER_Magic 0             &kp GRAVE                     &kp LBKT                      &kp RBKT       &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &thumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 5 — Colemak (macOS)
         * - Same non-alpha utility positions as the rest of the base family.
         * - Uses crumb on the typing-thumb instead of plain thumb for retro-tap.
         */
        layer_Colemak {
            bindings = <
                &none                           &none                           &none                           &none                           &none                                                                                                                                                                                                       &none                            &none                            &none                            &none                 &none
                &none                           &kp N1                          &kp N2                          &kp N3                          &kp N4  &kp N5                                                                                                                                                              &kp N6                           &kp N7                           &kp N8                           &kp N9                &kp N0   &none
                &none                           &kp Q                           &kp W                           &kp F                           &kp P   &kp G                                                                                                                                                               &kp J                            &kp L                            &kp U                            &kp Y                 &kp SEMI &kp MINUS
                &kp EQUAL       &_LeftPinky(A, LAYER_Colemak)  &_LeftRingy(R, LAYER_Colemak)  &_LeftMiddy(S, LAYER_Colemak)  &_LeftIndex(T, LAYER_Colemak)   &kp D                                                                                                                                                               &kp H   &_RightIndex(N, LAYER_Colemak)  &_RightMiddy(E, LAYER_Colemak)  &_RightRingy(I, LAYER_Colemak)  &_RightPinky(O, LAYER_Colemak)  &kp SQT
              &mo LAYER_Lower                   &kp Z                           &kp X                           &kp C                           &kp V   &kp B      &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp K  &kp M  &kp COMMA  &kp DOT  &kp FSLH  &mo LAYER_Lower
            &magic LAYER_Magic 0              &kp GRAVE                      &kp LBKT                        &kp RBKT        &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &crumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 6 — Colemak-DH (macOS)
         * - Colemak-DH alpha arrangement.
         * - Same dual-Lower edges, dual-Magic corners, and thumb utility fan.
         */
        layer_ColemakDH {
            bindings = <
                &none                              &none                              &none                              &none                              &none                                                                                                                                                                                                         &none                               &none                               &none                               &none                 &none
                &none                              &kp N1                             &kp N2                             &kp N3                             &kp N4  &kp N5                                                                                                                                                              &kp N6                              &kp N7                              &kp N8                              &kp N9                &kp N0   &none
                &none                              &kp Q                              &kp W                              &kp F                              &kp P   &kp B                                                                                                                                                               &kp J                               &kp L                               &kp U                               &kp Y                 &kp SEMI &kp MINUS
                &kp EQUAL      &_LeftPinky(A, LAYER_ColemakDH)  &_LeftRingy(R, LAYER_ColemakDH)  &_LeftMiddy(S, LAYER_ColemakDH)  &_LeftIndex(T, LAYER_ColemakDH)   &kp G                                                                                                                                                               &kp M  &_RightIndex(N, LAYER_ColemakDH)  &_RightMiddy(E, LAYER_ColemakDH)  &_RightRingy(I, LAYER_ColemakDH)  &_RightPinky(O, LAYER_ColemakDH)  &kp SQT
              &mo LAYER_Lower                      &kp Z                              &kp X                              &kp C                              &kp D   &kp V      &thumb LAYER_Function ESC  &parang_left  &parang_right  &kp _HOME  &kp _END  &thumb LAYER_System ENTER  &kp K  &kp H  &kp COMMA  &kp DOT  &kp FSLH  &mo LAYER_Lower
            &magic LAYER_Magic 0                 &kp GRAVE                         &kp LBKT                           &kp RBKT         &thumb LAYER_Emoji BSLH       &thumb LAYER_Cursor BACKSPACE  &thumb LAYER_Number DELETE  &thumb LAYER_Typing INSERT  &mo LAYER_Typing  &thumb LAYER_Mouse TAB  &space LAYER_Symbol SPACE  &thumb LAYER_World PAGE_UP  &msc MOUSE_SCROLL_UP  &msc MOUSE_SCROLL_DOWN  &lt LAYER_MouseWarp PG_DN  &magic LAYER_Magic 0
            >;
        };

        /*
         * Layer 7 — Typing (macOS helper layer)
         * - Mostly transparent.
         * - Exposes the raw current home-row and selected thumb positions so the
         *   transient typing mode can be used to recover literal keys from mod-taps.
         */
        layer_Typing {
            bindings = <
                &trans  &trans  &trans  &trans  &trans                                                                                                                         &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans  &trans                                                                                                    &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans  &trans                                                                                                    &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &kp LEFT_PINKY_KEY  &kp LEFT_RINGY_KEY  &kp LEFT_MIDDY_KEY  &kp LEFT_INDEX_KEY  &trans                                                          &trans  &kp RIGHT_INDEX_KEY  &kp RIGHT_MIDDY_KEY  &kp RIGHT_RINGY_KEY  &kp RIGHT_PINKY_KEY  &trans
                &trans  &trans  &trans  &trans  &trans  &trans  &kp KEY_LH_T1  &trans  &trans  &trans  &trans  &kp KEY_RH_T1  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &kp KEY_LH_C2R6  &kp KEY_LH_T4  &kp KEY_LH_T5  &kp KEY_LH_T6  &kp KEY_RH_T6  &kp KEY_RH_T5  &kp KEY_RH_T4  &kp KEY_RH_C2R6  &trans  &trans  &trans  &trans
            >;
        };

        /*
         * Layers 8-15 — Finger layers (macOS)
         * These are not "normal" user-facing layouts. Each one is a transient helper
         * layer entered while a specific home-row mod is resolving. The held finger
         * gets special tap replay behavior; the opposite hand remains available.
         */
        layer_LeftPinky {
            bindings = <
                &left_pinky_tap KEY_LH_C6R1  &left_pinky_tap KEY_LH_C5R1  &left_pinky_tap KEY_LH_C4R1  &left_pinky_tap KEY_LH_C3R1  &left_pinky_tap KEY_LH_C2R1                                                                                &trans  &trans  &trans  &trans  &trans
