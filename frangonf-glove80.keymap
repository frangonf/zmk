         *
         * These mirror the macOS stack. The key positions are intentionally similar,
         * but editing shortcuts, copy/paste/find aliases, and home-row modifier roles
         * follow the Linux-oriented definitions from the live behavior files.
         */

        layer_QWERTY_Linux {
            bindings = <
