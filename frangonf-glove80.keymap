        layer_Symbol {
            bindings = <
                &none  &none  &none  &none  &none                                                                                                         &none  &none  &none  &none  &none
                &kp GRAVE  &kp LBRC  &kp LBKT  &kp RBKT  &kp RBRC  &kp DOT                                                                          &none  &none  &none  &none  &none  &none
